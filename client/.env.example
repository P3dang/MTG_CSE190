# In development, leave blank — Vite proxy will forward /api requests to localhost:3001
# In production on Render, set this to your backend service URL (no trailing slash)
VITE_API_URL=

# Supabase — get these from your Supabase project: Settings → API
# Use the anon/public key here (NOT the service role key)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
